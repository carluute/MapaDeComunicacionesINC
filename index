// ══════════════════════════════════════════════════════
//  HELPERS
// ══════════════════════════════════════════════════════
const W = () => window.innerWidth, H = () => window.innerHeight;

function ncolor(d){
  if(d.avg_rating>=4.0) return '#39ff82';
  if(d.avg_rating>=3.5) return '#00e5ff';
  if(d.avg_rating>=2.5) return '#7b2fff';
  return '#ff6b35';
}
function nfilter(d){
  if(d.avg_rating>=4.0) return 'url(#fg)';
  if(d.avg_rating>=3.5) return 'url(#fc)';
  if(d.avg_rating>=2.5) return 'url(#fp)';
  return 'url(#fo)';
}

const degree = {};
EDGES.forEach(e=>{degree[e.source]=(degree[e.source]||0)+1;degree[e.target]=(degree[e.target]||0)+1;});
const nodes = NODES.map(n=>({...n,degree:degree[n.id]||0}));
const nodeById = Object.fromEntries(nodes.map(n=>[n.id,n]));
const nodeByName = Object.fromEntries(nodes.map(n=>[n.name.toUpperCase(),n]));

// channels per node
const nodeCh = {};
EDGES.forEach(e=>{
  [e.source,e.target].forEach(id=>{
    if(!nodeCh[id]) nodeCh[id]=new Set();
    e.channels.forEach(c=>nodeCh[id].add(c));
  });
});

// radius
const maxR = Math.sqrt(Math.max(...nodes.map(n=>n.mentions+n.respondents*2))||1);
function radius(d){ return 9 + (Math.sqrt(d.mentions+d.respondents*2)/maxR)*20; }

// stroke
const maxW2 = Math.max(...EDGES.map(e=>e.weight));
function sw(w){ return 0.5 + (w/maxW2)*4; }

// ══════════════════════════════════════════════════════
//  SVG SETUP
// ══════════════════════════════════════════════════════
const svg = d3.select('#gs');
const zg  = d3.select('#zg');
const ll  = d3.select('#ll');
const nl  = d3.select('#nl');

// ══════════════════════════════════════════════════════
//  SIMULATION — fluid, organic, alive
// ══════════════════════════════════════════════════════
const sim = d3.forceSimulation(nodes)
  .force('link', d3.forceLink(EDGES).id(d=>d.id)
    .distance(d => 160 - d.weight*8)
    .strength(d => 0.15 + d.weight*0.025))
  .force('charge', d3.forceManyBody()
    .strength(d => -280 - d.degree*12)
    .distanceMax(500))
  .force('center', d3.forceCenter(W()/2, H()/2).strength(0.035))
  .force('collide', d3.forceCollide(d => radius(d)+16))
  .force('x', d3.forceX(W()/2).strength(0.018))
  .force('y', d3.forceY(H()/2).strength(0.018))
  .alphaDecay(0.008)      // slow cooling = long organic motion
  .alphaMin(0.001)
  .velocityDecay(0.28);   // low damping = fluid, lively feel

let simRunning = true;

// ══════════════════════════════════════════════════════
//  LINKS
// ══════════════════════════════════════════════════════
const linkEls = ll.selectAll('line').data(EDGES).join('line')
  .attr('class','lnk')
  .attr('stroke','#00e5ff')
  .attr('stroke-opacity', d => 0.055 + d.weight*0.025)
  .attr('stroke-width', d => sw(d.weight));

// ══════════════════════════════════════════════════════
//  NODE GROUPS
// ══════════════════════════════════════════════════════
const ngs = nl.selectAll('g.ng').data(nodes).join('g').attr('class','ng')
  .call(d3.drag()
    .on('start', (ev,d)=>{ if(!ev.active) sim.alphaTarget(0.25).restart(); simRunning=true; updatePhysBtn(); d.fx=d.x; d.fy=d.y; })
    .on('drag',  (ev,d)=>{ d.fx=ev.x; d.fy=ev.y; })
    .on('end',   (ev,d)=>{ if(!ev.active) sim.alphaTarget(0.02); d.fx=null; d.fy=null; }));

// glow
ngs.append('circle')
  .attr('class', d => d.degree>18 ? 'ng-glow ng-pulse' : 'ng-glow')
  .attr('r', d => radius(d)*2.3)
  .attr('fill', d => ncolor(d))
  .attr('fill-opacity',.1);

// main
ngs.append('circle')
  .attr('class','ng-main')
  .attr('r', d => radius(d))
  .attr('fill', d => ncolor(d))
  .attr('fill-opacity',.78)
  .attr('stroke', d => ncolor(d))
  .attr('stroke-width', d => d.leaders>0 ? 2.5 : 0.7)
  .attr('stroke-opacity', 1)
  .style('filter', d => nfilter(d));

// labels — wrapped, high contrast
ngs.each(function(d){
  const g = d3.select(this);
  const r = radius(d);
  const words = d.name.split(' ');
  const lines = [];
  let cur = '';
  words.forEach(w=>{
    const test = (cur ? cur+' ' : '')+w;
    if(test.length > 20 && cur){ lines.push(cur); cur = w; }
    else cur = test;
  });
  if(cur) lines.push(cur);

  const lh = 12, pad = 4;
  const maxLen = Math.max(...lines.map(l=>l.length));
  const bw = maxLen*5.9+pad*2, bh = lines.length*lh+pad;
  const yOff = r+8;

  const lg = g.append('g').attr('class','lg').attr('transform',`translate(0,${yOff})`);
  lg.append('rect').attr('class','lbg')
    .attr('x',-bw/2).attr('y',-1)
    .attr('width',bw).attr('height',bh).attr('rx',3);
  lines.forEach((l,i)=>{
    lg.append('text').attr('class','lbl')
      .attr('x',0).attr('y', i*lh+lh-2).text(l);
  });
});

// ══════════════════════════════════════════════════════
//  TOOLTIP
// ══════════════════════════════════════════════════════
const tt = document.getElementById('tt');

ngs.on('mouseover',(ev,d)=>{
  hlNode(d);
  showTT(d);
})
.on('mousemove', ev => posTT(ev))
.on('mouseleave',()=>{ resetHL(); tt.classList.remove('vis'); });

function hlNode(d){
  const conn = new Set(EDGES.filter(e=>e.source.id===d.id||e.target.id===d.id)
    .flatMap(e=>[e.source.id,e.target.id]));
  linkEls
    .attr('stroke-opacity', e=>(e.source.id===d.id||e.target.id===d.id)?0.88:0.025)
    .attr('stroke-width', e=>(e.source.id===d.id||e.target.id===d.id)?sw(e.weight)*2.2:sw(e.weight)*.35)
    .attr('stroke', e=>(e.source.id===d.id||e.target.id===d.id)?ncolor(d):'#00e5ff');
  ngs.attr('opacity', nd=>conn.has(nd.id)||nd.id===d.id?1:0.1);
}

function resetHL(){
  linkEls.attr('stroke-opacity',d=>0.055+d.weight*0.025)
    .attr('stroke-width',d=>sw(d.weight)).attr('stroke','#00e5ff');
  ngs.attr('opacity',1);
}

function showTT(d){
  document.getElementById('tt-n').textContent = d.name;
  const dot = document.getElementById('tt-d');
  dot.style.background = ncolor(d); dot.style.boxShadow=`0 0 7px ${ncolor(d)}`;
  document.getElementById('tt-r').textContent = d.avg_rating.toFixed(1)+'/5';
  const rv = document.getElementById('tt-rv'); rv.innerHTML='';
  for(let i=1;i<=5;i++){
    const el=document.createElement('div');
    el.className='rd'+(i<=Math.round(d.avg_rating)?' f':'');
    rv.appendChild(el);
  }
  document.getElementById('tt-rsp').textContent = d.respondents;
  document.getElementById('tt-l').textContent = d.leaders>0?`✦ ${d.leaders}`:'—';
  document.getElementById('tt-deg').textContent = d.degree;
  document.getElementById('tt-m').textContent = d.mentions;
  const chs = nodeCh[d.id]?[...nodeCh[d.id]]:[];
  document.getElementById('tt-ch').innerHTML = chs.slice(0,8).map(c=>`<span class="ttch">${c}</span>`).join('');
  tt.classList.add('vis');
}

function posTT(ev){
  const tw=280,th=190,x=ev.clientX+16,y=ev.clientY-10;
  tt.style.left = (x+tw>window.innerWidth ? ev.clientX-tw-16:x)+'px';
  tt.style.top  = (y+th>window.innerHeight? ev.clientY-th:y)+'px';
}

// ══════════════════════════════════════════════════════
//  TICK
// ══════════════════════════════════════════════════════
sim.on('tick',()=>{
  linkEls.attr('x1',d=>d.source.x).attr('y1',d=>d.source.y)
         .attr('x2',d=>d.target.x).attr('y2',d=>d.target.y);
  ngs.attr('transform',d=>`translate(${d.x},${d.y})`);
});

// ══════════════════════════════════════════════════════
//  ZOOM
// ══════════════════════════════════════════════════════
const zoom = d3.zoom().scaleExtent([0.08,9])
  .on('zoom', ev => zg.attr('transform',ev.transform));
svg.call(zoom);

document.getElementById('bzi').onclick = ()=>svg.transition().duration(320).call(zoom.scaleBy,1.45);
document.getElementById('bzo').onclick = ()=>svg.transition().duration(320).call(zoom.scaleBy,0.69);
document.getElementById('brs').onclick = ()=>{
  svg.transition().duration(700).call(zoom.transform,
    d3.zoomIdentity.translate(window.innerWidth/2,window.innerHeight/2).scale(.75).translate(-window.innerWidth/2,-window.innerHeight/2));
};

// ══════════════════════════════════════════════════════
//  PHYSICS TOGGLE
// ══════════════════════════════════════════════════════
function updatePhysBtn(){
  const btn = document.getElementById('phys-btn');
  btn.textContent = simRunning ? '⏸' : '▶';
  btn.classList.toggle('active', simRunning);
}
document.getElementById('phys-btn').onclick = ()=>{
  simRunning = !simRunning;
  if(simRunning){ sim.alphaTarget(0.08).restart(); }
  else{ sim.stop(); }
  updatePhysBtn();
};

// ══════════════════════════════════════════════════════
//  SELECTION (ring)
// ══════════════════════════════════════════════════════
let selId = null, ring = null;

function selectNode(d){
  if(ring){ ring.remove(); ring=null; }
  if(selId===d.id){ selId=null; resetHL(); return; }
  selId=d.id;
  const el = nl.selectAll('g.ng').filter(nd=>nd.id===d.id);
  ring = el.append('circle').attr('class','ng-ring').attr('r',radius(d)+7);
  hlNode(d);
}

ngs.on('click',(ev,d)=>{ ev.stopPropagation(); selectNode(d); });
svg.on('click',()=>{ if(selId!==null){ selId=null; if(ring){ring.remove();ring=null;} resetHL(); } });

// ══════════════════════════════════════════════════════
//  SEARCH — AREA
// ══════════════════════════════════════════════════════
const ai=document.getElementById('ai'), ax=document.getElementById('ax'), ar=document.getElementById('ar');
ai.oninput=()=>{
  const q=ai.value.trim().toUpperCase();
  ax.style.display=q?'block':'none'; ar.innerHTML='';
  if(q.length<2) return;
  nodes.filter(n=>n.name.toUpperCase().includes(q)).slice(0,8).forEach(n=>{
    const el=document.createElement('div'); el.className='sri';
    el.innerHTML=`<div class="sri-n">${n.name}</div><div class="sri-s">Conexiones: ${n.degree} · Menciones: ${n.mentions} · Calidad: ${n.avg_rating.toFixed(1)}/5</div>`;
    el.onclick=()=>{ focusN(n); ar.innerHTML=''; ai.value=n.name; };
    ar.appendChild(el);
  });
};
ax.onclick=()=>{ ai.value=''; ax.style.display='none'; ar.innerHTML=''; resetHL(); clearSel(); };

function focusN(n){
  selectNode(n);
  const sc=1.6, x=window.innerWidth/2-n.x*sc, y=window.innerHeight/2-n.y*sc;
  svg.transition().duration(650).call(zoom.transform, d3.zoomIdentity.translate(x,y).scale(sc));
}
function clearSel(){ if(selId!==null){selId=null;if(ring){ring.remove();ring=null;}} }

// ══════════════════════════════════════════════════════
//  SEARCH — ROLE
// ══════════════════════════════════════════════════════
const ri2=document.getElementById('ri'), rx2=document.getElementById('rx');
const rr2=document.getElementById('rr'), rib=document.getElementById('rib');

ri2.oninput=()=>{
  const q=ri2.value.trim().toLowerCase();
  rx2.style.display=q?'block':'none'; rr2.innerHTML=''; rib.classList.remove('vis');
  if(q.length<2) return;
  ROLES.filter(r=>r.role.toLowerCase().includes(q)).slice(0,6).forEach(r=>{
    const el=document.createElement('div'); el.className='rri';
    const tags=r.areas.map(a=>`<span class="rat">${a}</span>`).join('');
    el.innerHTML=`<div class="rn">${r.role}${r.is_leader?' ✦':''}</div><div style="margin-top:3px">${tags}</div><div class="rc">Interactúa con <strong>${r.interacts_with.length}</strong> áreas</div>`;
    el.onclick=()=>showRib(r);
    rr2.appendChild(el);
  });
};
rx2.onclick=()=>{ ri2.value=''; rx2.style.display='none'; rr2.innerHTML=''; rib.classList.remove('vis'); resetHL(); clearSel(); };

function showRib(r){
  rr2.innerHTML=''; ri2.value=r.role;
  rib.classList.add('vis');
  document.getElementById('rib-t').textContent = r.role+(r.is_leader?' ✦ Liderazgo':'');
  document.getElementById('rib-a').textContent = r.areas.join(', ');
  const tset = new Set(r.interacts_with.map(x=>x.toUpperCase()));
  linkEls.attr('stroke-opacity',.025).attr('stroke-width',d=>sw(d.weight)*.3);
  ngs.attr('opacity', nd=>{
    if(r.areas.some(a=>nd.name.toUpperCase().includes(a.toUpperCase().trim()))) return 1;
    return tset.has(nd.name.toUpperCase())?0.82:0.08;
  });
  document.getElementById('rib-c').innerHTML = r.interacts_with
    .map(a=>`<span class="rice" onclick="focusNByName('${a.replace(/'/g,"\\'")}',event)">${a}</span>`).join('');
  document.getElementById('rib-ch').innerHTML = r.channels.map(c=>`<span class="chc">${c}</span>`).join('');
}

function focusNByName(name,ev){
  if(ev) ev.stopPropagation();
  const nd = nodes.find(n=>n.name.toUpperCase()===name.toUpperCase()||n.name.toUpperCase().includes(name.toUpperCase().trim()));
  if(nd) focusN(nd);
}

// ══════════════════════════════════════════════════════
//  KEYBOARD
// ══════════════════════════════════════════════════════
document.addEventListener('keydown',ev=>{
  if(ev.key==='+'||ev.key==='=') svg.transition().call(zoom.scaleBy,1.3);
  else if(ev.key==='-') svg.transition().call(zoom.scaleBy,.77);
  else if(ev.key==='Escape'){ resetHL(); rib.classList.remove('vis'); clearSel(); }
  else if(ev.key===' '){ ev.preventDefault();
    simRunning=!simRunning;
    simRunning?sim.alphaTarget(0.08).restart():sim.stop();
    updatePhysBtn();
  }
});

// ══════════════════════════════════════════════════════
//  STAR BACKGROUND
// ══════════════════════════════════════════════════════
(function(){
  const c=document.createElement('canvas');
  c.style.cssText='position:fixed;inset:0;z-index:0;pointer-events:none;';
  c.width=window.innerWidth; c.height=window.innerHeight;
  document.body.insertBefore(c,document.body.firstChild);
  const ctx=c.getContext('2d');
  for(let i=0;i<240;i++){
    ctx.beginPath();
    ctx.arc(Math.random()*c.width,Math.random()*c.height,Math.random()*.85+.1,0,Math.PI*2);
    ctx.fillStyle=`rgba(180,210,255,${Math.random()*.32+.04})`;
    ctx.fill();
  }
})();

window.addEventListener('resize',()=>{
  sim.force('center',d3.forceCenter(window.innerWidth/2,window.innerHeight/2));
  sim.alpha(.08).restart(); simRunning=true; updatePhysBtn();
});

updatePhysBtn();
</script>
</body>
</html>
