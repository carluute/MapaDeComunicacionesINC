@import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap');

:root {
  --bg:#04080f; --bg2:#060e1c;
  --c1:#00e5ff; --c2:#7b2fff; --c3:#ff6b35; --c4:#39ff82;
  --text:#c8d8e8; --dim:#3a5070;
  --panel:rgba(5,14,30,0.95); --border:rgba(0,229,255,0.14);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Space Mono',monospace;overflow:hidden;width:100vw;height:100vh;}
body::before{content:'';position:fixed;inset:0;background:
  radial-gradient(ellipse 75% 55% at 18% 28%,rgba(0,70,140,0.13) 0%,transparent 60%),
  radial-gradient(ellipse 55% 75% at 82% 72%,rgba(70,0,150,0.1) 0%,transparent 60%);
  pointer-events:none;z-index:0;}
#cv{position:fixed;inset:0;z-index:1;}
svg{width:100%;height:100%;}

/* LINKS */
.lnk{fill:none;stroke-linecap:round;transition:stroke-opacity .15s,stroke-width .15s;}

/* NODES */
.ng{cursor:grab;}
.ng:active{cursor:grabbing;}
.ng-glow{pointer-events:none;}
@keyframes pulse{0%,100%{opacity:.09;transform:scale(1);}50%{opacity:.19;transform:scale(1.14);}}
.ng-pulse{animation:pulse 3.2s ease-in-out infinite;transform-origin:center;transform-box:fill-box;}
.ng-ring{fill:none;stroke:#fff;stroke-width:2.5;stroke-dasharray:5 3;
  animation:spin 5s linear infinite;transform-origin:center;transform-box:fill-box;pointer-events:none;}
@keyframes spin{to{transform:rotate(360deg);}}

/* LABELS */
.lbg{fill:rgba(4,8,20,.72);pointer-events:none;}
.lbl{font-family:'Syne',sans-serif;font-size:10.5px;font-weight:700;fill:#ddeeff;
  pointer-events:none;text-anchor:middle;letter-spacing:.02em;}

/* HEADER */
#hdr{position:fixed;top:0;left:0;right:0;z-index:50;display:flex;align-items:center;
  justify-content:space-between;padding:12px 22px;
  background:linear-gradient(to bottom,rgba(4,8,15,.95) 0%,transparent 100%);pointer-events:none;}
.ht{font-family:'Syne',sans-serif;font-size:12.5px;font-weight:800;color:var(--c1);
  letter-spacing:.1em;text-transform:uppercase;}
.hs{font-size:8.5px;color:var(--dim);letter-spacing:.06em;margin-top:2px;}
.hstats{display:flex;gap:18px;}
.sn{font-family:'Syne',sans-serif;font-size:17px;font-weight:800;color:var(--text);line-height:1;}
.sl{font-size:7.5px;color:var(--dim);text-transform:uppercase;letter-spacing:.1em;}

/* SEARCH */
#sc{position:fixed;top:76px;left:22px;z-index:60;width:272px;display:flex;flex-direction:column;gap:10px;}
.sp{background:var(--panel);border:1px solid var(--border);border-radius:10px;
  padding:12px 14px;backdrop-filter:blur(22px);box-shadow:0 4px 28px rgba(0,0,0,.55);}
.slbl{font-family:'Syne',sans-serif;font-size:8.5px;font-weight:700;color:var(--dim);
  text-transform:uppercase;letter-spacing:.12em;margin-bottom:7px;display:flex;align-items:center;gap:5px;}
.si-wrap{position:relative;}
.si{width:100%;background:rgba(0,229,255,.045);border:1px solid rgba(0,229,255,.18);
  border-radius:6px;padding:8px 30px 8px 11px;font-family:'Space Mono',monospace;
  font-size:10.5px;color:var(--text);outline:none;transition:border-color .2s,background .2s;}
.si:focus{border-color:rgba(0,229,255,.55);background:rgba(0,229,255,.075);}
.si::placeholder{color:var(--dim);}
.sx{position:absolute;right:9px;top:50%;transform:translateY(-50%);color:var(--dim);
  cursor:pointer;font-size:15px;display:none;transition:color .15s;}
.sx:hover{color:var(--c1);}
.sr{margin-top:7px;max-height:170px;overflow-y:auto;
  scrollbar-width:thin;scrollbar-color:rgba(0,229,255,.25) transparent;}
.sri{padding:6px 9px;border-radius:5px;cursor:pointer;font-size:9.5px;color:var(--text);
  transition:background .15s;border:1px solid transparent;margin-bottom:3px;line-height:1.4;}
.sri:hover,.sri.sel{background:rgba(0,229,255,.08);border-color:rgba(0,229,255,.22);color:var(--c1);}
.sri-n{font-weight:700;font-size:10px;}
.sri-s{font-size:8px;color:var(--dim);margin-top:2px;}
.rri{padding:7px 9px;border-radius:5px;cursor:pointer;font-size:9.5px;border:1px solid transparent;
  margin-bottom:4px;line-height:1.5;transition:background .15s;}
.rri:hover,.rri.sel{background:rgba(123,47,255,.14);border-color:rgba(123,47,255,.32);}
.rn{font-weight:700;font-size:10px;color:#b8a0ff;}
.rat{display:inline-block;background:rgba(123,47,255,.12);border:1px solid rgba(123,47,255,.28);
  border-radius:3px;padding:1px 5px;font-size:7.5px;color:#c8b4ff;margin:2px 2px 0 0;}
.rc{font-size:8px;color:var(--dim);margin-top:3px;}

/* ROLE INFO */
#rib{display:none;background:var(--panel);border:1px solid rgba(123,47,255,.38);
  border-radius:10px;padding:12px 14px;backdrop-filter:blur(22px);
  box-shadow:0 4px 28px rgba(0,0,0,.55);}
#rib.vis{display:block;}
.rit{font-family:'Syne',sans-serif;font-size:10px;font-weight:800;color:#b8a0ff;
  text-transform:uppercase;letter-spacing:.07em;margin-bottom:8px;}
.ria{font-size:9px;color:var(--dim);margin-bottom:5px;}
.rict{font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:.08em;margin:7px 0 5px;}
.rices{display:flex;flex-wrap:wrap;gap:3px;}
.rice{background:rgba(0,229,255,.07);border:1px solid rgba(0,229,255,.18);border-radius:4px;
  padding:2px 7px;font-size:8px;color:var(--c1);cursor:pointer;transition:background .15s;}
.rice:hover{background:rgba(0,229,255,.16);}
.chcs{display:flex;flex-wrap:wrap;gap:3px;margin-top:5px;}
.chc{background:rgba(57,255,130,.07);border:1px solid rgba(57,255,130,.18);border-radius:3px;
  padding:2px 6px;font-size:7.5px;color:var(--c4);}

/* TOOLTIP */
#tt{position:fixed;z-index:100;pointer-events:none;opacity:0;transition:opacity .18s;max-width:280px;}
#tt.vis{opacity:1;}
.ttb{background:var(--panel);border:1px solid var(--border);border-radius:8px;padding:13px 15px;
  backdrop-filter:blur(22px);box-shadow:0 8px 36px rgba(0,0,0,.7);}
.ttt{font-family:'Syne',sans-serif;font-size:11px;font-weight:800;color:var(--c1);
  text-transform:uppercase;letter-spacing:.04em;margin-bottom:9px;line-height:1.4;}
.ttr{display:flex;align-items:center;gap:7px;margin-bottom:4px;font-size:9.5px;}
.ttd{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.ttlb{color:var(--dim);margin-right:2px;}
.rdv{display:flex;gap:3px;margin-left:3px;}
.rd{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.09);}
.rd.f{background:var(--c4);}
.ttchs{margin-top:8px;display:flex;flex-wrap:wrap;gap:3px;}
.ttch{background:rgba(0,229,255,.07);border:1px solid rgba(0,229,255,.18);border-radius:3px;
  padding:2px 6px;font-size:8px;color:var(--c1);letter-spacing:.03em;}

/* LEGEND */
#leg{position:fixed;bottom:22px;right:74px;z-index:50;background:var(--panel);
  border:1px solid var(--border);border-radius:8px;padding:13px 15px;backdrop-filter:blur(16px);}
.legt{font-family:'Syne',sans-serif;font-size:8.5px;font-weight:700;color:var(--dim);
  text-transform:uppercase;letter-spacing:.1em;margin-bottom:9px;}
.legr{display:flex;align-items:center;gap:7px;margin-bottom:5px;font-size:9px;color:var(--text);}
.legsw{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.legln{width:20px;height:2px;flex-shrink:0;border-radius:1px;}

/* CONTROLS */
#ctrl{position:fixed;bottom:22px;right:22px;z-index:50;display:flex;flex-direction:column;gap:7px;}
.cb{width:36px;height:36px;background:var(--panel);border:1px solid var(--border);border-radius:6px;
  color:var(--text);font-size:17px;cursor:pointer;display:flex;align-items:center;justify-content:center;
  transition:background .18s,border-color .18s;backdrop-filter:blur(12px);font-family:'Space Mono',monospace;}
.cb:hover{background:rgba(0,229,255,.09);border-color:rgba(0,229,255,.38);}

/* PHYSICS TOGGLE */
#phys-btn{font-size:11px;letter-spacing:.02em;}
#phys-btn.active{background:rgba(57,255,130,.1);border-color:rgba(57,255,130,.4);color:var(--c4);}

/* AUTHOR */
#auth{position:fixed;bottom:22px;left:22px;z-index:50;background:var(--panel);
  border:1px solid var(--border);border-radius:8px;padding:9px 13px;backdrop-filter:blur(16px);}
.an{font-family:'Syne',sans-serif;font-size:9px;font-weight:700;color:var(--c1);letter-spacing:.03em;}
.am{font-size:7px;color:var(--dim);margin-top:2px;line-height:1.5;}
.av{font-size:7px;color:rgba(57,255,130,.6);margin-top:1px;}

@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
#cv{animation:fadeIn 1.2s ease;}
</style>
</head>
